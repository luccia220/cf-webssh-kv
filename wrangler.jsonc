{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cf-webssh-kv",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-20",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "kv_namespaces": [
    {
      "binding": "WEBSSH_KV"
      "id": "80ff1e61a7e849cca745b179e9426138"


    }
  ],
  "observability": {
    "enabled": true
  }
}
