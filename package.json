{
  "name": "cf-webssh",
  "version": "1.1.1",
  "private": true,
  "type": "module",
  "description": "A password-protected WebSSH dashboard for Cloudflare Workers, Workers KV and GitHub deployments.",
  "scripts": {
    "dev": "pnpm run build && wrangler dev",
    "dev:ui": "node scripts/copy-wasm.mjs && vite",
    "copy:wasm": "node scripts/copy-wasm.mjs",
    "build": "node scripts/copy-wasm.mjs && tsc -b && vite build",
    "deploy": "pnpm run build && wrangler deploy",
    "typecheck": "tsc -b",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.10.0",
    "@xterm/xterm": "5.5.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sshclient-wasm": "0.1.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260719.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "typescript": "5.9.3",
    "vite": "6.4.3",
    "wrangler": "4.112.0"
  },
  "engines": {
    "node": "22.x"
  },
  "packageManager": "pnpm@10.11.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
